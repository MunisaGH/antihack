# ==============================================================
# Production environment — serverda `.env.production` deb saqlang
# Secrets qo'lda to'ldiriladi, git'ga commit qilinmaydi
# ==============================================================

# --- Django core ---
DEBUG=False
SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM
ALLOWED_HOSTS=your-domain.com,YOUR_PRODUCTION_IP

# HTTPS proxy orqali keladi, nginx terminate qiladi
SECURE_SSL_REDIRECT=False
NUM_PROXIES=1

# --- CORS & CSRF ---
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# --- Database (alohida DB server) ---
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=career_ai
DATABASE_USER=career_ai_user
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_HOST=YOUR_DB_SERVER_IP
DATABASE_PORT=5432
DATABASE_SSLMODE=require
DATABASE_CONNECT_TIMEOUT=10
DATABASE_CONN_MAX_AGE=60

# --- AI / Gemini ---
GEMINI_API_KEY=CHANGE_ME_GEMINI_KEY
AI_MODEL=gemini-2.5-pro
AI_FAST_MODEL=gemini-2.5-flash
AI_CLASSIFIER_MODEL=gemini-2.5-flash-lite
AI_TEMPERATURE=0.3
AI_INTERVIEW_MAX_QUESTIONS=10
AI_MIN_COMPATIBILITY_SCORE=60
AI_DEFAULT_THRESHOLD=70

# --- Rate limiting ---
THROTTLE_SUBMIT_APPLICATION=60/hour
THROTTLE_CONTACT_MESSAGE=30/hour

# --- Static/Media ---
STATIC_URL=/static/
MEDIA_URL=/media/

# --- Object storage: DigitalOcean Spaces (private) + Bunny CDN (token-signed) ---
# Arxitektura:
#  * Spaces PRIVATE bucket — backend boto3 orqali yozadi/o'qiydi.
#  * Bunny Pull Zone S3 auth orqali Spaces'dan pull qiladi va CDN orqali tarqatadi.
#  * Download URL'lar Bunny token authentication bilan signed (1 soat amal).
# Shared Space: bir nechta app (hiring, doctors, ...) bitta Space ichida prefiks orqali.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=career-ai
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_LOCATION=hiring

# Bunny CDN — scheme BILAN to'liq URL ("https://..." formatida)
BUNNY_CDN_URL=https://career-ai.b-cdn.net
# Bunny dashboard → Pull Zone → Security → Token Authentication Key
BUNNY_TOKEN_KEY=
# Signed URL amal qiladigan vaqt (sekund) — default 3600 (1 soat)
BUNNY_TOKEN_EXPIRY_SECONDS=3600

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_DAYS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=10

# --- Locale ---
TIME_ZONE=Asia/Tashkent
LANGUAGE_CODE=uz

# --- API docs ---
API_SERVER_URL=https://your-domain.com
